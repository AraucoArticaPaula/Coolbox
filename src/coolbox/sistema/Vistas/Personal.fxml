<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
   prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26"
   xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="coolbox.sistema.Controladores.PersonalController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="220.0"
         style="-fx-background-color: black;" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0"
               style="-fx-background-color: transparent;">
               <children>
                  <ImageView fitHeight="100.0" fitWidth="180.0" pickOnBounds="true"
                     preserveRatio="true">
                     <image>
                        <Image url="@LOGO%20COOLBOX.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
               prefWidth="220.0"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
               VBox.vgrow="ALWAYS">
               <content>
                  <VBox prefWidth="218.0" spacing="4.0" style="-fx-background-color: transparent;">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                     <children>
                        <Label fx:id="lblNombreUsuarioSidebar" alignment="CENTER"
                           maxWidth="Infinity"
                           style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px; -fx-font-family: 'Tw Cen MT'; -fx-font-weight: bold; -fx-padding: 0 0 12 0;"
                           text="..." wrapText="true" />

                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           style="-fx-background-color: #CC0000; -fx-text-fill: #FFFFFF; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  👥  Personal" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irASeguridad"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  🔐  Seguridad" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irAAlmacen"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  📦  Almacén" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irAOperaciones"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  💰  Operaciones" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irAReportes"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  📊  Reportes" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#abrirPerfil"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  👤  Mi perfil" />
                        <Button alignment="CENTER" maxWidth="Infinity" prefHeight="38.0"
                           onAction="#cerrarSesion"
                           style="-fx-background-color: transparent; -fx-text-fill: #FF6666; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  🚪  Cerrar sesión" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>

      <VBox prefHeight="600.0" style="-fx-background-color: #F8F9FA;" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="220.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Separator prefWidth="200.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="49.0"
               style="-fx-background-color: white; -fx-padding: 0 20 0 20;">
               <children>
                  <Label alignment="CENTER" prefHeight="31.0" text="Personal" textFill="#222222">
                     <font>
                        <Font name="System Bold" size="21.0" />
                     </font>
                  </Label>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label fx:id="lblTiendaPrincipal"
                     style="-fx-background-color: #E8F5E9; -fx-text-fill: #2E7D32; -fx-padding: 6 14 6 14; -fx-background-radius: 6; -fx-font-weight: bold; -fx-font-size: 13px; -fx-border-color: #C8E6C9; -fx-border-radius: 6;"
                     text="🏪 SUCURSAL: CARGANDO..." />
               </children>
            </HBox>
            <Separator prefWidth="200.0" />

            <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
               <tabs>
                  <Tab text="👥 Lista de empleados">
                     <content>
                        <VBox spacing="15.0">
                           <padding>
                              <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                           </padding>
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Button fx:id="btnNuevoEmpleado" mnemonicParsing="false"
                                       onAction="#abrirModalRegistrar" prefHeight="32.0"
                                       style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="+ Registrar empleado" />
                                    <Button fx:id="btnCambiarTiendaCargo" mnemonicParsing="false"
                                       onAction="#abrirModalCambiarTiendaCargo" prefHeight="32.0"
                                       style="-fx-background-color: #17A2B8; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="🔄 Cambiar tienda/cargo" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Button fx:id="btnBajaEmpleado" mnemonicParsing="false"
                                       onAction="#eliminarEmpleado" prefHeight="32.0"
                                       style="-fx-background-color: #DC3545; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="❌ Dar de baja" />
                                    <Button fx:id="btnDeshabilitarEmpleado" mnemonicParsing="false"
                                       onAction="#deshabilitarEmpleado" prefHeight="32.0"
                                       style="-fx-background-color: #FFC107; -fx-text-fill: #212121; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="⏸ Deshabilitar" />
                                 </children>
                              </HBox>
                              <TableView fx:id="tblEmpleados" style="-fx-background-radius: 8;"
                                 VBox.vgrow="ALWAYS">
                                 <columns>
                                    <TableColumn fx:id="colNombres" prefWidth="150.0" text="Nombres" />
                                    <TableColumn fx:id="colApellidos" prefWidth="150.0"
                                       text="Apellidos" />
                                    <TableColumn fx:id="colDNI" prefWidth="90.0" text="DNI" />
                                    <TableColumn fx:id="colCelular" prefWidth="100.0" text="Celular" />
                                    <TableColumn fx:id="colCorreo" prefWidth="160.0" text="Correo" />
                                    <TableColumn fx:id="colTipo" prefWidth="60.0" text="Tipo" />
                                    <TableColumn fx:id="colNombreTienda" prefWidth="180.0"
                                       text="Sucursal" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                  </Tab>
                  <Tab text="📅 Horarios y cumplimiento">
                     <content>
                        <HBox spacing="15.0">
                           <padding>
                              <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                           </padding>
                           <children>
                              <VBox prefWidth="370.0" spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <VBox spacing="8.0"
                                       style="-fx-background-color: #E9ECEF; -fx-padding: 10; -fx-border-color: #DEE2E6; -fx-border-radius: 5; -fx-background-radius: 5;">
                                       <HBox alignment="CENTER_LEFT" spacing="15.0">
                                          <Label fx:id="lblFechaActualHorario"
                                             text="Hoy: 00/00/0000"
                                             style="-fx-font-weight: bold; -fx-text-fill: #0056b3; -fx-font-size: 13px;" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button mnemonicParsing="false"
                                             onAction="#abrirModalRegistrarHorario"
                                             style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand; -fx-font-weight: bold;"
                                             text="+ Asignar turno" />
                                       </HBox>
                                       <HBox alignment="CENTER_LEFT" spacing="8.0">
                                          <Label text="Ver desde:"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold;"
                                             prefWidth="60.0" />
                                          <DatePicker fx:id="dpHorarioInicio" prefWidth="120.0" />
                                          <Label text="Hasta el:"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold;"
                                             prefWidth="50.0" />
                                          <DatePicker fx:id="dpHorarioFin" disable="true"
                                             prefWidth="120.0" style="-fx-opacity: 1;" />
                                       </HBox>
                                       <HBox alignment="CENTER_LEFT" spacing="8.0">
                                          <Label text="Filtrar día:"
                                             style="-fx-font-size: 11px; -fx-font-weight: bold;"
                                             prefWidth="60.0" />
                                          <ComboBox fx:id="cmbHorarioDia" prefWidth="120.0"
                                             promptText="Día" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button mnemonicParsing="false" onAction="#buscarHorarios"
                                             prefHeight="26.0" prefWidth="90.0"
                                             style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-background-radius: 4; -fx-cursor: hand; -fx-font-weight: bold;"
                                             text="🔍 Buscar" />
                                       </HBox>
                                    </VBox>
                                    <TableView fx:id="tblHorarios" style="-fx-background-radius: 8;"
                                       VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colHorarioEmpleado" prefWidth="140.0"
                                             text="Empleado" />
                                          <TableColumn fx:id="colHorarioDia" prefWidth="85.0"
                                             text="Día" />
                                          <TableColumn fx:id="colHorarioInicio" prefWidth="70.0"
                                             text="Inicio" />
                                          <TableColumn fx:id="colHorarioFin" prefWidth="70.0"
                                             text="Fin" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                              <VBox prefWidth="370.0" spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <HBox alignment="CENTER_LEFT">
                                       <children>
                                          <Label style="-fx-font-weight: bold; -fx-font-size: 14px;"
                                             text="Validación de horas semanales" textFill="#333333" />
                                          <Region HBox.hgrow="ALWAYS" />
                                          <Button mnemonicParsing="false"
                                             onAction="#abrirModalValidarCumplimiento"
                                             style="-fx-background-color: #17A2B8; -fx-text-fill: white; -fx-background-radius: 5; -fx-cursor: hand;"
                                             text="✓ Validar horas" />
                                       </children>
                                    </HBox>
                                    <TableView fx:id="tblCumplimiento"
                                       style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colCumpEmpleado" prefWidth="130.0"
                                             text="Empleado" />
                                          <TableColumn fx:id="colCumpHoras" prefWidth="70.0"
                                             text="Horas" />
                                          <TableColumn fx:id="colCumpPeriodo" prefWidth="80.0"
                                             text="Periodo" />
                                          <TableColumn fx:id="colCumpEstado" prefWidth="85.0"
                                             text="Estado" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </content>
                  </Tab>
               </tabs>
            </TabPane>
         </children>
      </VBox>
   </children>
</AnchorPane>