<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ProgressBar?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="700.0" prefWidth="950.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coolbox.sistema.Controladores.Modales.ModalRegistrarHorarioController">
   <children>
      <VBox prefHeight="700.0" prefWidth="950.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <VBox spacing="4.0">
               <children>
                  <HBox alignment="CENTER_LEFT">
                     <children>
                        <Label text="Cronograma general de ocupación semanal" textFill="#222222">
                           <font>
                              <Font name="System Bold" size="20.0" />
                           </font>
                        </Label>
                        <Region HBox.hgrow="ALWAYS" />
                        <Label fx:id="lblTiendaCabecera" style="-fx-background-color: #E1F5FE; -fx-text-fill: #0288D1; -fx-padding: 6 12 6 12; -fx-background-radius: 20; -fx-font-weight: bold; -fx-font-size: 12px;" text="Tienda: Cargando..." />
                     </children>
                  </HBox>
                  <Label text="Planifique los rangos de cada colaborador. Los bloques se pintarán de colores únicos con el nombre del empleado respectivo." textFill="#666666">
                     <font>
                        <Font size="11.5" />
                     </font>
                  </Label>
               </children>
            </VBox>

            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #E9ECEF; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #DEE2E6; -fx-border-radius: 6;">
               <children>
                  <Label style="-fx-font-weight: bold;" text="Vigencia de la Semana:" textFill="#444444" />
                  <Label text="Fecha inicio:" />
                  <DatePicker fx:id="dpFechaInicio" prefWidth="140.0" />
                  <Label text="Fecha fin:" />
                  <DatePicker fx:id="dpFechaFin" prefWidth="140.0" />
               </children>
            </HBox>
            
            <HBox alignment="CENTER_LEFT" spacing="15.0" style="-fx-background-color: #F8F9FA; -fx-padding: 12; -fx-background-radius: 6; -fx-border-color: #E2E3E5; -fx-border-radius: 6;">
               <children>
                  <VBox prefWidth="280.0" spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Seleccionar colaborador activo *" textFill="#444444" />
                        <ComboBox fx:id="cmbEmpleado" maxWidth="Infinity" onAction="#onEmpleadoSeleccionado" prefHeight="35.0" promptText="Seleccionar empleado..." style="-fx-background-radius: 5; -fx-background-color: white; -fx-border-color: #CCCCCC; -fx-border-radius: 5;" />
                     </children>
                  </VBox>
                  <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                     <children>
                        <HBox alignment="BOTTOM_LEFT">
                           <children>
                              <Label fx:id="lblJornadaInfo" style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Jornada: seleccione un colaborador" textFill="#555555" />
                              <Region HBox.hgrow="ALWAYS" />
                              <Label fx:id="lblContadorHoras" style="-fx-font-weight: bold; -fx-font-size: 12px;" text="0 / 0 hrs asignadas a este empleado" textFill="#CC0000" />
                           </children>
                        </HBox>
                        <ProgressBar fx:id="progressHoras" maxWidth="Infinity" prefHeight="15.0" progress="0.0" style="-fx-accent: #28A745;" />
                     </children>
                  </VBox>
               </children>
            </HBox>

            <HBox alignment="BOTTOM_LEFT" spacing="12.0" style="-fx-background-color: #F1F3F5; -fx-padding: 12; -fx-background-radius: 6; -fx-border-color: #DEE2E6;">
               <children>
                  <VBox prefWidth="140.0" spacing="4.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Día de destino *" textFill="#444444" />
                        <ComboBox fx:id="cmbPickerDia" maxWidth="Infinity" prefHeight="32.0" promptText="Día..." style="-fx-background-radius: 5; -fx-background-color: white;" />
                     </children>
                  </VBox>
                  <VBox prefWidth="150.0" spacing="4.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Hora de inicio *" textFill="#444444" />
                        <ComboBox fx:id="cmbPickerInicio" maxWidth="Infinity" prefHeight="32.0" promptText="Desde..." style="-fx-background-radius: 5; -fx-background-color: white;" />
                     </children>
                  </VBox>
                  <VBox prefWidth="150.0" spacing="4.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 11px;" text="Hora de término *" textFill="#444444" />
                        <ComboBox fx:id="cmbPickerFin" maxWidth="Infinity" prefHeight="32.0" promptText="Hasta..." style="-fx-background-radius: 5; -fx-background-color: white;" />
                     </children>
                  </VBox>
                  <Button mnemonicParsing="false" onAction="#asignarRangoBloque" prefHeight="32.0" prefWidth="120.0" style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="🔹 Pintar" />
                  <Button mnemonicParsing="false" onAction="#limpiarMatriz" prefHeight="32.0" prefWidth="90.0" style="-fx-background-color: #6C757D; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="🔄 Limpiar" />
                  <Button mnemonicParsing="false" onAction="#exportarCronogramaAExcel" prefHeight="32.0" prefWidth="130.0" style="-fx-background-color: #17A2B8; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="📥 Exportar Excel" />
               </children>
            </HBox>

            <VBox spacing="6.0" VBox.vgrow="ALWAYS">
               <children>
                  <TableView fx:id="tblMatrizHorario" prefHeight="320.0" prefWidth="910.0" style="-fx-background-radius: 6;">
                    <columns>
                      <TableColumn fx:id="colTramo" prefWidth="160.0" style="-fx-font-weight: bold;" text="Rango horario" />
                      <TableColumn fx:id="colLunes" prefWidth="105.0" text="Lunes" />
                      <TableColumn fx:id="colMartes" prefWidth="105.0" text="Martes" />
                      <TableColumn fx:id="colMiercoles" prefWidth="105.0" text="Miercoles" />
                      <TableColumn fx:id="colJueves" prefWidth="105.0" text="Jueves" />
                      <TableColumn fx:id="colViernes" prefWidth="105.0" text="Viernes" />
                      <TableColumn fx:id="colSabado" prefWidth="105.0" text="Sabado" />
                      <TableColumn fx:id="colDomingo" prefWidth="105.0" text="Domingo" />
                    </columns>
                     <columnResizePolicy>
                        <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                     </columnResizePolicy>
                  </TableView>
               </children>
            </VBox>
            
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #E0E0E0; -fx-text-fill: #444444; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />
                  <Button fx:id="btnGuardar" disable="true" mnemonicParsing="false" onAction="#guardarHorarioSemanas" prefHeight="36.0" prefWidth="200.0" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="Guardar cambios totales" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>