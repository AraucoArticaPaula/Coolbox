                  <Button fx:id="btnGuardar" mnemonicParsing="false" onAction="#guardarAsignacionRol" prefHeight="36.0" prefWidth="140.0" style="-fx-background-color: #6C757D; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="Otorgar Rol" />
