<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="500.0" prefWidth="650.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="tu.paquete.ModalRegistrarVentaController">
   <children>
      <VBox prefHeight="500.0" prefWidth="650.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <HBox alignment="CENTER_LEFT">
               <children>
                  <VBox spacing="2.0">
                     <children>
                        <Label text="Punto de venta - registrar ticket" textFill="#222222">
                           <font>
                              <Font name="System Bold" size="18.0" />
                           </font>
                        </Label>
                        <Label text="Escanee o digite el ID del producto para consultar la base de datos." textFill="#666666">
                           <font>
                              <Font size="11.5" />
                           </font>
                        </Label>
                     </children>
                  </VBox>
                  <Region HBox.hgrow="ALWAYS" />
                  <Label style="-fx-background-color: #FFF3CD; -fx-text-fill: #856404; -fx-padding: 6 12 6 12; -fx-background-radius: 4; -fx-font-weight: bold;" text="BOLETA ELECTRÓNICA" />
               </children>
            </HBox>
            
            <Separator prefWidth="200.0" />
            
            <HBox spacing="15.0" VBox.vgrow="ALWAYS">
               <children>
                  
                  <VBox prefWidth="230.0" spacing="12.0">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 13px;" text="Datos de la Transacción" textFill="#333333" />
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Tienda *" textFill="#555555" />
                              <ComboBox fx:id="cmbTienda" maxWidth="Infinity" prefHeight="32.0" promptText="Seleccionar sucursal..." style="-fx-background-radius: 5; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-color: #FAFAFA;" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Vendedor *" textFill="#555555" />
                              <ComboBox fx:id="cmbEmpleado" maxWidth="Infinity" prefHeight="32.0" promptText="Seleccionar vendedor..." style="-fx-background-radius: 5; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-color: #FAFAFA;" />
                           </children>
                        </VBox>
                        
                        <VBox spacing="4.0">
                           <children>
                              <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="Garantías Extendidas Vendidas" textFill="#555555" />
                              <TextField fx:id="txtGarantias" prefHeight="32.0" style="-fx-background-radius: 5; -fx-border-color: #CCCCCC; -fx-border-radius: 5; -fx-background-color: #FAFAFA;" text="0" />
                           </children>
                        </VBox>
                        
                        <Separator prefWidth="200.0" />
                        
                        <VBox spacing="8.0" style="-fx-background-color: #F8F9FA; -fx-background-radius: 6; -fx-padding: 10; -fx-border-color: #E0E0E0; -fx-border-radius: 6;">
                           <children>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label text="Items Totales:" textFill="#666666" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblTotalProductos" style="-fx-font-weight: bold;" text="0" textFill="#222222" />
                                 </children>
                              </HBox>
                              <HBox alignment="CENTER_LEFT">
                                 <children>
                                    <Label style="-fx-font-weight: bold;" text="TOTAL A PAGAR:" textFill="#cc0000" />
                                    <Region HBox.hgrow="ALWAYS" />
                                    <Label fx:id="lblTotalMonto" style="-fx-font-weight: bold; -fx-font-size: 16px;" text="S/ 0.00" textFill="#cc0000" />
                                 </children>
                              </HBox>
                           </children>
                        </VBox>
                     </children>
                  </VBox>
                  
                  <VBox spacing="10.0" HBox.hgrow="ALWAYS">
                     <children>
                        <Label style="-fx-font-weight: bold; -fx-font-size: 13px;" text="Detalle del Comprobante" textFill="#333333" />
                        
                        <HBox alignment="BOTTOM_LEFT" spacing="8.0" style="-fx-background-color: #F1F3F5; -fx-padding: 10; -fx-background-radius: 6; -fx-border-color: #DEE2E6; -fx-border-radius: 6;">
                           <children>
                              <VBox prefWidth="80.0" spacing="4.0">
                                 <children>
                                    <Label style="-fx-font-size: 11px; -fx-font-weight: bold;" text="ID Producto" />
                                    <TextField fx:id="txtIdProductoInput" onAction="#buscarProductoEnBD" prefHeight="32.0" promptText="Ej. 1" style="-fx-background-radius: 5; -fx-border-color: #CCCCCC;" />
                                 </children>
                              </VBox>
                              
                              <VBox alignment="CENTER_LEFT" spacing="2.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-font-size: 10px;" text="Producto detectado:" textFill="#666666" />
                                    <Label fx:id="lblNombreProductoDetectado" style="-fx-font-weight: bold; -fx-font-size: 12px;" text="Digite un ID y presione Enter..." textFill="#333333" />
                                 </children>
                                 <padding>
                                    <Insets left="5.0" />
                                 </padding>
                              </VBox>
                              
                              <VBox alignment="CENTER_LEFT" prefWidth="75.0" spacing="2.0">
                                 <children>
                                    <Label style="-fx-font-size: 10px;" text="Precio:" textFill="#666666" />
                                    <Label fx:id="lblPrecioProductoDetectado" style="-fx-font-weight: bold; -fx-font-size: 13px;" text="S/ 0.00" textFill="#28A745" />
                                 </children>
                              </VBox>
                              
                              <Button mnemonicParsing="false" onAction="#agregarItemATabla" prefHeight="32.0" prefWidth="35.0" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-background-radius: 5; -fx-font-weight: bold; -fx-cursor: hand;" text="+" />
                           </children>
                        </HBox>
                        
                        <TableView fx:id="tblDetalleVenta" prefHeight="200.0" prefWidth="200.0" style="-fx-background-radius: 6;" VBox.vgrow="ALWAYS">
                          <columns>
                            <TableColumn fx:id="colIdProd" prefWidth="65.0" text="ID" />
                            <TableColumn fx:id="colDescripcion" prefWidth="210.0" text="Descripción del Producto" />
                            <TableColumn fx:id="colPrecio" prefWidth="85.0" text="Precio" />
                          </columns>
                           <columnResizePolicy>
                              <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                           </columnResizePolicy>
                        </TableView>
                     </children>
                  </VBox>
                  
               </children>
            </HBox>
            
            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" prefHeight="36.0" prefWidth="100.0" style="-fx-background-color: #E0E0E0; -fx-text-fill: #444444; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />
                  <Button fx:id="btnGuardarImprimir" mnemonicParsing="false" onAction="#guardarVentaEImprimir" prefHeight="36.0" prefWidth="180.0" style="-fx-background-color: #CC0000; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="💳 Guardar e Imprimir PDF" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>
