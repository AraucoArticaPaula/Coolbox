<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="380.0" prefWidth="480.0" style="-fx-background-color: #FFFFFF;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coolbox.sistema.Controladores.Modales.ModalRecibirTrasladoController">
   <children>
      <VBox prefHeight="380.0" prefWidth="480.0" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="25.0" left="25.0" right="25.0" top="25.0" />
         </padding>
         <children>
            <VBox spacing="5.0">
               <children>
                  <Label text="📥 Confirmar Recepción de Traslado" textFill="#222222">
                     <font>
                        <Font name="System Bold" size="18.0" />
                     </font>
                  </Label>
                  <Label text="Verifique la mercadería física antes de dar conformidad al stock." textFill="#666666">
                     <font>
                        <Font size="12.0" />
                     </font>
                  </Label>
               </children>
            </VBox>
            
            <VBox spacing="12.0" VBox.vgrow="ALWAYS">
               <children>
                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Producto a Recibir:" textFill="#444444" />
                        <TextField fx:id="txtProducto" editable="false" prefHeight="35.0" style="-fx-background-color: #E9ECEF; -fx-background-radius: 6; -fx-border-color: #CCCCCC; -fx-border-radius: 6; -fx-text-fill: #495057;" />
                     </children>
                  </VBox>
                  
                  <HBox spacing="15.0">
                     <children>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-weight: bold;" text="Sede de Origen:" textFill="#444444" />
                              <TextField fx:id="txtOrigen" editable="false" prefHeight="35.0" style="-fx-background-color: #E9ECEF; -fx-background-radius: 6; -fx-border-color: #CCCCCC; -fx-border-radius: 6; -fx-text-fill: #495057;" />
                           </children>
                        </VBox>
                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                           <children>
                              <Label style="-fx-font-weight: bold;" text="Cantidad Enviada:" textFill="#444444" />
                              <TextField fx:id="txtCantidad" editable="false" prefHeight="35.0" style="-fx-background-color: #E9ECEF; -fx-background-radius: 6; -fx-border-color: #CCCCCC; -fx-border-radius: 6; -fx-text-fill: #495057;" />
                           </children>
                        </VBox>
                     </children>
                  </HBox>

                  <VBox spacing="5.0">
                     <children>
                        <Label style="-fx-font-weight: bold;" text="Gerente / Subgerente de tu sede (Firma Conforme) *" textFill="#CC0000" />
                        <ComboBox fx:id="cmbResponsableDestino" maxWidth="Infinity" prefHeight="35.0" promptText="Seleccionar responsable de recepción..." style="-fx-background-radius: 6; -fx-border-color: #CCCCCC; -fx-border-radius: 6; -fx-background-color: #FAFAFA;" />
                     </children>
                  </VBox>
               </children>
            </VBox>

            <HBox alignment="CENTER_RIGHT" spacing="12.0">
               <children>
                  <Button fx:id="btnCancelar" mnemonicParsing="false" onAction="#cerrarModal" prefHeight="35.0" prefWidth="100.0" style="-fx-background-color: #E0E0E0; -fx-text-fill: #444444; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="Cancelar" />
                  <Button mnemonicParsing="false" onAction="#confirmarRecepcion" prefHeight="35.0" prefWidth="150.0" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;" text="📥 Aceptar Ingreso" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>