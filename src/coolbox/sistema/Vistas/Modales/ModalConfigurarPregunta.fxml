<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>

<!--
  ================================================================
  ModalConfigurarPregunta.fxml — Configurar pregunta de seguridad
  ================================================================
  Se abre automáticamente tras el login si el usuario no tiene
  pregunta de seguridad registrada. No se puede cerrar sin guardar.
  Controlador: coolbox.sistema.Controladores.Modales.ModalConfigurarPreguntaController
  ================================================================
-->

<VBox prefWidth="440" spacing="0"
      style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0, 0, 4);"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="coolbox.sistema.Controladores.Modales.ModalConfigurarPreguntaController">

    <!-- CABECERA -->
    <HBox alignment="CENTER_LEFT"
          style="-fx-background-color: #CC0000; -fx-padding: 18 24 18 24;">
        <VBox spacing="3" HBox.hgrow="ALWAYS">
            <Label text="🔐  Configura tu pregunta de seguridad"
                   style="-fx-text-fill: white; -fx-font-size: 15px; -fx-font-weight: bold;"/>
            <Label text="Obligatorio — necesaria para recuperar tu contraseña"
                   style="-fx-text-fill: rgba(255,255,255,0.8); -fx-font-size: 11px;"/>
        </VBox>
    </HBox>

    <!-- AVISO -->
    <HBox alignment="CENTER_LEFT" spacing="10"
          style="-fx-background-color: #fff8e1; -fx-border-color: #ffe082;
                 -fx-border-width: 0 0 1 0; -fx-padding: 12 20 12 20;">
        <Label text="⚠" style="-fx-font-size: 16px; -fx-text-fill: #f57f17;"/>
        <Label text="Tu cuenta no tiene pregunta de seguridad. Sin ella no podrás recuperar tu contraseña si la olvidas."
               wrapText="true" maxWidth="370"
               style="-fx-font-size: 12px; -fx-text-fill: #5d4037;"/>
    </HBox>

    <!-- CUERPO -->
    <VBox spacing="0" style="-fx-padding: 24 28 24 28;">

        <!-- Pregunta -->
        <Label text="Selecciona una pregunta de seguridad"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        <Region prefHeight="6"/>
        <ComboBox fx:id="cmbPregunta" maxWidth="Infinity" promptText="Elige una pregunta..."
                  style="-fx-font-size: 13px;"/>

        <Region prefHeight="16"/>

        <!-- Respuesta -->
        <Label text="Tu respuesta"
               style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
        <Region prefHeight="4"/>
        <Label text="Usa algo que solo tú sepas y puedas recordar fácilmente."
               style="-fx-font-size: 11px; -fx-text-fill: #888;"/>
        <Region prefHeight="6"/>
        <TextField fx:id="txtRespuesta" promptText="Tu respuesta..."
                   style="-fx-font-size: 13px; -fx-border-color: #ddd; -fx-border-radius: 5;
                          -fx-background-radius: 5; -fx-padding: 9 12 9 12;"/>

        <Region prefHeight="6"/>
        <Label fx:id="lblError" text="" wrapText="true" visible="false" managed="false"
               style="-fx-text-fill: #CC0000; -fx-font-size: 12px;"/>

        <Region prefHeight="24"/>

        <!-- Botón — sin cancelar, es obligatorio -->
        <Button fx:id="btnGuardar" onAction="#onGuardar"
                text="Guardar y continuar →"
                maxWidth="Infinity" defaultButton="true"
                style="-fx-background-color: #CC0000; -fx-text-fill: white;
                       -fx-font-size: 14px; -fx-font-weight: bold; -fx-cursor: hand;
                       -fx-padding: 12 0 12 0; -fx-background-radius: 5;"/>

        <Region prefHeight="8"/>
        <Label text="Este dato se guarda de forma segura y solo se usa para recuperar tu contraseña."
               wrapText="true" maxWidth="384"
               style="-fx-font-size: 11px; -fx-text-fill: #aaa; -fx-text-alignment: center;"
               HBox.hgrow="ALWAYS"/>
    </VBox>

</VBox>
