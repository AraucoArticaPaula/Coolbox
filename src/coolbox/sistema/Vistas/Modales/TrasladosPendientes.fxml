<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane prefHeight="400.0" prefWidth="600.0" style="-fx-background-color: white;" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="coolbox.sistema.Controladores.Modales.ModalTrasladosPendientesController">
   <children>
      <VBox prefHeight="400.0" prefWidth="600.0" spacing="15.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
         </padding>
         <children>
            <Label text="📦 Envíos Pendientes por Confirmar" textFill="#222222">
               <font><Font name="System Bold" size="18.0" /></font>
            </Label>
            <TableView fx:id="tblPendientes" VBox.vgrow="ALWAYS">
               <columns>
                  <TableColumn fx:id="colProd" prefWidth="200.0" text="Producto" />
                  <TableColumn fx:id="colOrig" prefWidth="120.0" text="Sede Origen" />
                  <TableColumn fx:id="colCant" prefWidth="100.0" text="Cantidad" />
               </columns>
            </TableView>
            <HBox alignment="CENTER_RIGHT" spacing="10.0">
               <children>
                  <Button fx:id="btnCerrar" onAction="#cerrar" prefHeight="32.0" prefWidth="90.0" text="Cerrar" />
                  <Button onAction="#procesarSeleccionado" prefHeight="32.0" prefWidth="150.0" style="-fx-background-color: #28A745; -fx-text-fill: white; -fx-font-weight: bold;" text="Procesar Ingreso" />
               </children>
            </HBox>
         </children>
      </VBox>
   </children>
</AnchorPane>