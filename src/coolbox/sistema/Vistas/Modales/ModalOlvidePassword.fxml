<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
  ================================================================
  ModalOlvidePassword.fxml — Recuperar contraseña (3 pasos)
  ================================================================
  Paso 1 → Ingresa correo         (paneStep1)
  Paso 2 → Responde pregunta      (paneStep2)
  Paso 3 → Nueva contraseña       (paneStep3)
  Paso 4 → Confirmación final     (paneExito)

  Controlador: coolbox.sistema.Controladores.Modales.ModalOlvidePasswordController
  ================================================================
-->

<VBox prefWidth="440" spacing="0"
      style="-fx-background-color: white; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.18), 18, 0, 0, 4);"
      xmlns:fx="http://javafx.com/fxml/1"
      xmlns="http://javafx.com/javafx/21"
      fx:controller="coolbox.sistema.Controladores.Modales.ModalOlvidePasswordController">

    <!-- ══════════════════════════════════════════
         CABECERA
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER_LEFT" spacing="0"
          style="-fx-background-color: #CC0000; -fx-padding: 18 20 18 24;">
        <Label fx:id="lblTitulo" text="Recuperar contraseña"
               style="-fx-text-fill: white; -fx-font-size: 17px; -fx-font-weight: bold;"
               maxWidth="Infinity" HBox.hgrow="ALWAYS"/>
        <Button onAction="#onCerrar" text="✕" focusTraversable="false"
                style="-fx-background-color: transparent; -fx-text-fill: white;
                       -fx-font-size: 15px; -fx-cursor: hand; -fx-padding: 2 6 2 6;"/>
    </HBox>

    <!-- ══════════════════════════════════════════
         INDICADOR DE PASOS  (1 · 2 · 3)
    ══════════════════════════════════════════ -->
    <HBox alignment="CENTER" spacing="0"
          style="-fx-background-color: #f7f7f7; -fx-border-color: #e0e0e0; -fx-border-width: 0 0 1 0; -fx-padding: 12 0 12 0;">

        <VBox alignment="CENTER" spacing="4" prefWidth="130">
            <Label fx:id="lblDot1" text="●"
                   style="-fx-text-fill: #CC0000; -fx-font-size: 20px;"/>
            <Label text="Correo" style="-fx-font-size: 11px; -fx-text-fill: #444;"/>
        </VBox>

        <Label text="──────"
               style="-fx-text-fill: #ccc; -fx-font-size: 13px;"/>

        <VBox alignment="CENTER" spacing="4" prefWidth="130">
            <Label fx:id="lblDot2" text="○"
                   style="-fx-text-fill: #aaa; -fx-font-size: 20px;"/>
            <Label fx:id="lblStep2Lbl" text="Verificación"
                   style="-fx-font-size: 11px; -fx-text-fill: #aaa;"/>
        </VBox>

        <Label text="──────"
               style="-fx-text-fill: #ccc; -fx-font-size: 13px;"/>

        <VBox alignment="CENTER" spacing="4" prefWidth="130">
            <Label fx:id="lblDot3" text="○"
                   style="-fx-text-fill: #aaa; -fx-font-size: 20px;"/>
            <Label fx:id="lblStep3Lbl" text="Nueva clave"
                   style="-fx-font-size: 11px; -fx-text-fill: #aaa;"/>
        </VBox>
    </HBox>

    <!-- ══════════════════════════════════════════
         CUERPO  (StackPane con los 3 paneles)
    ══════════════════════════════════════════ -->
    <StackPane VBox.vgrow="ALWAYS">

        <!-- ─────────────────────────────────────
             PASO 1: Correo electrónico
        ───────────────────────────────────── -->
        <VBox fx:id="paneStep1" spacing="0" visible="true" managed="true"
              style="-fx-padding: 28 30 28 30;">

            <Label text="Ingresa tu correo registrado"
                   style="-fx-font-size: 13px; -fx-text-fill: #555; -fx-wrap-text: true;"/>

            <Region prefHeight="20"/>

            <Label text="Correo electrónico"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region prefHeight="6"/>
            <TextField fx:id="txtCorreo" promptText="ejemplo@coolbox.com"
                       style="-fx-font-size: 13px; -fx-border-color: #ddd; -fx-border-radius: 5;
                              -fx-background-radius: 5; -fx-padding: 9 12 9 12;"/>

            <Region prefHeight="8"/>
            <Label fx:id="lblErrorStep1" text="" wrapText="true" managed="false" visible="false"
                   style="-fx-text-fill: #CC0000; -fx-font-size: 12px;"/>

            <Region prefHeight="24"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onCerrar" text="Cancelar"
                        style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 20 9 20;
                               -fx-background-radius: 5;"/>
                <Button onAction="#onVerificarCorreo" text="Continuar →"
                        defaultButton="true"
                        style="-fx-background-color: #CC0000; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 24 9 24;
                               -fx-background-radius: 5;"/>
            </HBox>
        </VBox>

        <!-- ─────────────────────────────────────
             PASO 2: Pregunta de seguridad
        ───────────────────────────────────── -->
        <VBox fx:id="paneStep2" spacing="0" visible="false" managed="false"
              style="-fx-padding: 28 30 28 30;">

            <Label text="Responde tu pregunta de seguridad"
                   style="-fx-font-size: 13px; -fx-text-fill: #555;"/>

            <Region prefHeight="20"/>

            <Label text="Pregunta"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region prefHeight="6"/>
            <Label fx:id="lblPregunta" text=""
                   wrapText="true"
                   style="-fx-font-size: 13px; -fx-text-fill: #222;
                          -fx-background-color: #f4f4f4; -fx-border-color: #e0e0e0;
                          -fx-border-radius: 5; -fx-background-radius: 5;
                          -fx-padding: 10 14 10 14;"/>

            <Region prefHeight="16"/>

            <Label text="Tu respuesta"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region prefHeight="6"/>
            <TextField fx:id="txtRespuesta" promptText="Ingresa la respuesta..."
                       style="-fx-font-size: 13px; -fx-border-color: #ddd; -fx-border-radius: 5;
                              -fx-background-radius: 5; -fx-padding: 9 12 9 12;"/>

            <Region prefHeight="8"/>
            <Label fx:id="lblErrorStep2" text="" wrapText="true" managed="false" visible="false"
                   style="-fx-text-fill: #CC0000; -fx-font-size: 12px;"/>

            <Region prefHeight="24"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onVolverStep1" text="← Atrás"
                        style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 20 9 20;
                               -fx-background-radius: 5;"/>
                <Button onAction="#onVerificarRespuesta" text="Verificar →"
                        defaultButton="true"
                        style="-fx-background-color: #CC0000; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 24 9 24;
                               -fx-background-radius: 5;"/>
            </HBox>
        </VBox>

        <!-- ─────────────────────────────────────
             PASO 3: Nueva contraseña
        ───────────────────────────────────── -->
        <VBox fx:id="paneStep3" spacing="0" visible="false" managed="false"
              style="-fx-padding: 28 30 28 30;">

            <Label text="Crea tu nueva contraseña"
                   style="-fx-font-size: 13px; -fx-text-fill: #555;"/>

            <Region prefHeight="20"/>

            <Label text="Nueva contraseña"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region prefHeight="6"/>
            <PasswordField fx:id="txtNueva"
                           promptText="Mínimo 6 caracteres"
                           style="-fx-font-size: 13px; -fx-border-color: #ddd; -fx-border-radius: 5;
                                  -fx-background-radius: 5; -fx-padding: 9 12 9 12;"/>

            <Region prefHeight="14"/>

            <Label text="Confirmar contraseña"
                   style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #333;"/>
            <Region prefHeight="6"/>
            <PasswordField fx:id="txtConfirmar"
                           promptText="Repite la contraseña"
                           style="-fx-font-size: 13px; -fx-border-color: #ddd; -fx-border-radius: 5;
                                  -fx-background-radius: 5; -fx-padding: 9 12 9 12;"/>

            <Region prefHeight="8"/>
            <Label fx:id="lblErrorStep3" text="" wrapText="true" managed="false" visible="false"
                   style="-fx-text-fill: #CC0000; -fx-font-size: 12px;"/>

            <Region prefHeight="24"/>

            <HBox alignment="CENTER_RIGHT" spacing="10">
                <Button onAction="#onVolverStep2" text="← Atrás"
                        style="-fx-background-color: #e0e0e0; -fx-text-fill: #333;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 20 9 20;
                               -fx-background-radius: 5;"/>
                <Button onAction="#onCambiarContrasena" text="Guardar cambio"
                        defaultButton="true"
                        style="-fx-background-color: #CC0000; -fx-text-fill: white;
                               -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 9 24 9 24;
                               -fx-background-radius: 5;"/>
            </HBox>
        </VBox>

        <!-- ─────────────────────────────────────
             CONFIRMACIÓN FINAL
        ───────────────────────────────────── -->
        <VBox fx:id="paneExito" spacing="0" visible="false" managed="false"
              alignment="CENTER"
              style="-fx-padding: 40 30 40 30;">

            <Label text="✔" style="-fx-font-size: 52px; -fx-text-fill: #22a94f;"/>
            <Region prefHeight="14"/>
            <Label text="¡Contraseña actualizada!"
                   style="-fx-font-size: 16px; -fx-font-weight: bold; -fx-text-fill: #222;"/>
            <Region prefHeight="8"/>
            <Label text="Ya puedes iniciar sesión con tu nueva contraseña."
                   wrapText="true" style="-fx-font-size: 13px; -fx-text-fill: #555;"
                   maxWidth="300"/>
            <Region prefHeight="28"/>
            <Button onAction="#onCerrar" text="Cerrar"
                    style="-fx-background-color: #22a94f; -fx-text-fill: white;
                           -fx-font-size: 13px; -fx-cursor: hand; -fx-padding: 10 40 10 40;
                           -fx-background-radius: 5;"/>
        </VBox>

    </StackPane>

</VBox>
