<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<!--
  ================================================================
  ModalOlvidePassword.fxml — Modal: ¿Olvidaste tu contraseña?
  ================================================================
  Se abre desde LoginController → onOlvidePassword()
  mediante Stage secundario (Modality.APPLICATION_MODAL).

  Tabla relacionada:
    - USUARIOS  (correo → para identificar cuenta)
    - EMPLEADOS (correo → verificación cruzada)

  Controlador : com.coolbox.controllers.ModalOlvidePasswordController
  CSS         : /com/coolbox/css/login.css  (mismo archivo)
  ================================================================
-->

<VBox prefHeight="320" prefWidth="420" spacing="0" style="-fx-background-color: white;" styleClass="modal-root" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/26" fx:controller="coolbox.sistema.Controladores.ModalOlvidePasswordController">

    <!-- ── Cabecera roja ── -->
    <HBox alignment="CENTER_LEFT" spacing="0" styleClass="modal-header">
        <padding><Insets bottom="18" left="24" right="20" top="18" /></padding>
        <Label maxWidth="Infinity" prefHeight="20.0" prefWidth="348.0" styleClass="modal-header-title" text="Recuperar contraseña" HBox.hgrow="ALWAYS">
         <font>
            <Font name="System Bold" size="20.0" />
         </font></Label>
        <Button focusTraversable="false" onAction="#onCerrar" styleClass="modal-close-btn" text="✕" />
    </HBox>

    <!-- ── Cuerpo ── -->
    <VBox prefWidth="420.0" spacing="0" styleClass="modal-body" VBox.vgrow="ALWAYS">
        <padding><Insets bottom="28" left="28" right="28" top="28" /></padding>

        <Label styleClass="modal-body-text" text="Ingresa el correo asociado a tu cuenta. El administrador recibirá la solicitud de restablecimiento." wrapText="true" />

        <Region prefHeight="20" />

        <!-- ── Campo correo ── -->
        <Label styleClass="field-label" text="Correo electrónico" />
        <Region prefHeight="6" />
        <TextField fx:id="txtCorreo" promptText="ejemplo@coolbox.com" styleClass="input-field" />

        <Region prefHeight="6" />
        <Label fx:id="lblErrorCorreo" managed="false" styleClass="field-error" text="" visible="false" />

        <!-- ── Banner éxito ── -->
        <HBox fx:id="paneExito" alignment="CENTER_LEFT" managed="false" spacing="8" styleClass="exito-banner" visible="false">
            <padding><Insets bottom="10" left="14" right="14" top="10" /></padding>
            <Label styleClass="exito-icon" text="✓" />
            <Label maxWidth="290" styleClass="exito-text" text="Solicitud enviada. Contacta a tu administrador." wrapText="true" />
        </HBox>

        <Region prefHeight="24" />

        <!-- ── Botones ── -->
        <HBox alignment="CENTER_RIGHT" spacing="12">
            <Button onAction="#onCerrar" style="-fx-background-color: red;" styleClass="btn-secondary" text="Cancelar" textFill="WHITE" />
            <Button fx:id="btnEnviar" defaultButton="true" onAction="#onEnviar" prefWidth="160" style="-fx-background-color: #00ff1a;" styleClass="btn-login" text="Enviar solicitud" textFill="WHITE" />
        </HBox>

    </VBox>

</VBox>
