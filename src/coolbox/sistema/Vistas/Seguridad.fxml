<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.text.Font?>

<AnchorPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity"
   prefHeight="600.0" prefWidth="1000.0" xmlns="http://javafx.com/javafx/26"
   xmlns:fx="http://javafx.com/fxml/1"
   fx:controller="coolbox.sistema.Controladores.SeguridadController">
   <children>
      <VBox alignment="TOP_CENTER" prefHeight="600.0" prefWidth="220.0"
         style="-fx-background-color: black;" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <VBox alignment="CENTER" prefHeight="130.0" prefWidth="220.0"
               style="-fx-background-color: transparent;">
               <children>
                  <ImageView fitHeight="100.0" fitWidth="180.0" pickOnBounds="true"
                     preserveRatio="true">
                     <image>
                        <Image url="@LOGO%20COOLBOX.png" />
                     </image>
                  </ImageView>
               </children>
            </VBox>
            <ScrollPane fitToHeight="true" fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="NEVER"
               prefWidth="220.0"
               style="-fx-background: transparent; -fx-background-color: transparent; -fx-border-color: transparent;"
               VBox.vgrow="ALWAYS">
               <content>
                  <VBox prefWidth="218.0" spacing="4.0" style="-fx-background-color: transparent;">
                     <padding>
                        <Insets bottom="10.0" left="10.0" right="10.0" top="5.0" />
                     </padding>
                     <children>
                        <Label fx:id="lblNombreUsuarioSidebar" alignment="CENTER"
                           maxWidth="Infinity"
                           style="-fx-text-fill: #AAAAAA; -fx-font-size: 13px; -fx-font-family: 'Tw Cen MT'; -fx-font-weight: bold; -fx-padding: 0 0 12 0;"
                           text="..." wrapText="true" />

                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irPersonal"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  👥  Personal" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           style="-fx-background-color: #CC0000; -fx-text-fill: #FFFFFF; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  🔐  Seguridad" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irAlmacen"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  📦  Almacén" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irOperaciones"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  💰  Operaciones" />
                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#irReportes"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  📊  Reportes" />

                        <Region VBox.vgrow="ALWAYS" />

                        <Button alignment="CENTER_LEFT" maxWidth="Infinity" prefHeight="38"
                           onAction="#abrirPerfil"
                           style="-fx-background-color: transparent; -fx-text-fill: #CCCCCC; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -fx-background-radius: 10; -fx-cursor: hand; -fx-border-color: transparent;"
                           text="  👤  Mi perfil" />
                        <Button alignment="CENTER" maxWidth="Infinity" prefHeight="38.0"
                           onAction="#cerrarSesion"
                           style="-fx-background-color: transparent; -fx-text-fill: #FF6666; -fx-font-family: 'Tw Cen MT'; -fx-font-size: 13px; -background-radius: 10; -cursor: hand; -border-color: transparent;"
                           text="  🚪  Cerrar sesión" />
                     </children>
                  </VBox>
               </content>
            </ScrollPane>
         </children>
      </VBox>

      <VBox prefHeight="600.0" style="-fx-background-color: #F8F9FA;" AnchorPane.bottomAnchor="0.0"
         AnchorPane.leftAnchor="220.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
         <children>
            <Separator prefWidth="200.0" />
            <HBox alignment="CENTER_LEFT" prefHeight="49.0"
               style="-fx-background-color: white; -fx-padding: 0 20 0 20;">
               <children>
                  <Label alignment="CENTER" prefHeight="31.0" text="Seguridad" textFill="#222222">
                     <font>
                        <Font name="System Bold" size="21.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <Separator prefWidth="200.0" />

            <TabPane stylesheets="@estilo_tabs_limpio.css" tabClosingPolicy="UNAVAILABLE"
               VBox.vgrow="ALWAYS">
               <tabs>
                  <Tab text="👤 Cuentas de usuario">
                     <content>
                        <VBox spacing="15.0">
                           <padding>
                              <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                           </padding>
                           <children>
                              <HBox alignment="CENTER_LEFT" spacing="10.0">
                                 <children>
                                    <Button fx:id="btnCrearUsuario" mnemonicParsing="false"
                                       onAction="#abrirModalCrearUsuario" prefHeight="32.0"
                                       style="-fx-background-color: #007BFF; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="+ Crear usuario" />
                                    <Button fx:id="btnAsignarRol" mnemonicParsing="false"
                                       onAction="#abrirModalAsignarRol" prefHeight="32.0"
                                       style="-fx-background-color: #6C757D; -fx-text-fill: white; -fx-background-radius: 6; -fx-font-weight: bold; -fx-cursor: hand;"
                                       text="🔑 Asignar rol extra" />
                                 </children>
                              </HBox>
                              <TableView fx:id="tblUsuarios" style="-fx-background-radius: 8;"
                                 VBox.vgrow="ALWAYS">
                                 <columns>
                                    <TableColumn fx:id="colNombreEmpleado" prefWidth="220.0"
                                       text="Nombre empleado" />
                                    <TableColumn fx:id="colUsername" prefWidth="160.0"
                                       text="Nombre usuario" />
                                    <TableColumn fx:id="colCorreoUsuario" prefWidth="220.0"
                                       text="Correo electrónico" />
                                    <TableColumn fx:id="colEstadoUsuario" prefWidth="120.0"
                                       text="Estado" />
                                 </columns>
                                 <columnResizePolicy>
                                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                 </columnResizePolicy>
                              </TableView>
                           </children>
                        </VBox>
                     </content>
                  </Tab>
                  <Tab text="  Matriz de roles">
                     <content>
                        <HBox spacing="15.0">
                           <padding>
                              <Insets bottom="15.0" left="20.0" right="20.0" top="15.0" />
                           </padding>
                           <children>
                              <VBox prefWidth="370.0" spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;"
                                       text="Roles por usuario" textFill="#333333" />
                                    <TableView fx:id="tblUsuariosRoles"
                                       style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colURUsuario" prefWidth="150.0"
                                             text="Usuario" />
                                          <TableColumn fx:id="colURRol" prefWidth="150.0"
                                             text="Rol asignado" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                              <VBox prefWidth="370.0" spacing="10.0" HBox.hgrow="ALWAYS">
                                 <children>
                                    <Label style="-fx-font-weight: bold; -fx-font-size: 14px;"
                                       text="Permisos por rol" textFill="#333333" />
                                    <TableView fx:id="tblRolesPermisos"
                                       style="-fx-background-radius: 8;" VBox.vgrow="ALWAYS">
                                       <columns>
                                          <TableColumn fx:id="colRPRol" prefWidth="130.0" text="Rol" />
                                          <TableColumn fx:id="colRPPermiso" prefWidth="170.0"
                                             text="Permiso autorizado" />
                                       </columns>
                                       <columnResizePolicy>
                                          <TableView fx:constant="CONSTRAINED_RESIZE_POLICY" />
                                       </columnResizePolicy>
                                    </TableView>
                                 </children>
                              </VBox>
                           </children>
                        </HBox>
                     </content>
                  </Tab>
               </tabs>
            </TabPane>
         </children>
      </VBox>
   </children>
</AnchorPane>